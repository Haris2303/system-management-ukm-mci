@startuml
skinparam ActivityBackgroundColor #DDEEFF
skinparam ActivityBorderColor #336699
skinparam ArrowColor #336699
skinparam ActivityDiamondBackgroundColor #FFF8DC
skinparam ActivityDiamondBorderColor #CC9900
skinparam ActivityFontName Times New Roman
skinparam ArrowFontName Times New Roman
skinparam DefaultFontSize 24
skinparam TitleFontSize 24
skinparam Padding 3

|Bendahara|
|Sistem|
|Anggota|

title Activity Diagram Pengelolaan Kas

|Bendahara|
start
:Membuka menu e-kas;

|Sistem|
:Menampilkan dasbor saldo\ndan riwayat transaksi;

|Bendahara|
:Memilih jenis aktivitas;

if (Jenis aktivitas?) then (Catat Transaksi)
  :Mengisi nominal, kategori,\ndan keterangan transaksi;
  :Menekan "Simpan";
  |Sistem|
  if (Input valid?) then (Tidak)
    :Menampilkan pesan error;
    stop
  else (Ya)
  endif
  :Menyimpan transaksi ke basis data;
  :Memperbarui saldo total;
  :Menampilkan "Transaksi berhasil dicatat";
else (Kelola Tagihan Anggota)
  :Memilih anggota yang\nakan diperbarui statusnya;
  :Mengubah status pembayaran\nmenjadi "Lunas";
  :Menekan "Simpan";
  |Sistem|
  :Memperbarui status\npembayaran anggota;
  :Menampilkan "Status berhasil diperbarui";
endif

|Anggota|
:Membuka menu informasi kas\npada aplikasi mobile;

|Sistem|
:Menampilkan status tagihan\ndan riwayat pembayaran\nsesuai data anggota;

|Anggota|
:Memantau status tagihan;
stop
@enduml
